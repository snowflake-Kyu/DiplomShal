<Window x:Class="WPFPPShall.FormDisciplines"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:WPFPPShall"
        mc:Ignorable="d"
        Title="Предметы и голосование" Height="700" Width="900">

    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="Auto"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- Заголовок -->
        <TextBlock Grid.Row="0" Grid.ColumnSpan="2"
                   Text="📚 Предметы (дисциплины) и голосование"
                   FontFamily="Segoe UI"
                   FontSize="18"
                   FontWeight="SemiBold"
                   Foreground="#2C3E50"
                   Margin="0,0,0,12"/>

        <!-- Левая колонка: Таблица предметов + фильтр -->
        <Border Grid.Row="1" Grid.Column="0"
                Grid.RowSpan="2"
                Margin="0,0,8,0"
                Background="White"
                CornerRadius="8"
                BorderBrush="#D1D5DB" BorderThickness="1"
                Padding="4">
            <DockPanel LastChildFill="True">
                <!-- Фильтр -->
                <StackPanel DockPanel.Dock="Top"
                            Orientation="Horizontal"
                            Margin="0,0,0,6"
                            Background="#F9FAFB">
                    <TextBlock Text="🔍 Фильтр:"
                               VerticalAlignment="Center"
                               Margin="0,0,6,0"
                               FontWeight="SemiBold"/>
                    <TextBox x:Name="TxtFilterDiscipline"
                             Width="160"
                             Height="24"
                             TextChanged="TxtFilterDiscipline_TextChanged"
                             Padding="2"/>
                </StackPanel>

                <!-- Сама таблица -->
                <DataGrid x:Name="DisciplinesGrid"
                          AutoGenerateColumns="False"
                          IsReadOnly="True"
                          HeadersVisibility="Column"
                          GridLinesVisibility="Horizontal"
                          SelectionMode="Single"
                          SelectionUnit="FullRow"
                          RowHeight="28"
                          Margin="0"
                          AlternationCount="2"
                          SelectionChanged="DisciplinesGrid_SelectionChanged"
                          BorderThickness="0">
                    <DataGrid.Columns>

                        <DataGridTextColumn Header="Название предмета"
                                            Binding="{Binding Name}"
                                            Width="Auto"/>
                    </DataGrid.Columns>
                </DataGrid>
            </DockPanel>
        </Border>

        <Border Grid.Row="1" Grid.Column="1"
                Background="White"
                CornerRadius="8"
                BorderBrush="#D1D5DB" BorderThickness="1"
                Padding="12"
                Margin="0,0,0,8">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <!-- Заголовок -->
                    <RowDefinition Height="Auto"/>
                    <!-- Название -->
                    <RowDefinition Height="*"/>
                    <!-- Описание -->
                    <RowDefinition Height="Auto"/>
                    <!-- Кнопки -->
                </Grid.RowDefinitions>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <TextBlock Grid.Row="0" Grid.Column="0" Grid.ColumnSpan="2"
                           Text="✏️ Редактирование предмета"
                           FontSize="14"
                           FontWeight="Bold"
                           Foreground="#2C3E50"
                           Margin="0,0,0,8"/>

                <TextBlock Grid.Row="1" Grid.Column="0"
                           Text="Название:"
                           Margin="0,0,8,8"
                           VerticalAlignment="Center"/>
                <TextBox x:Name="TxtName"
                         Grid.Row="1" Grid.Column="1"
                         Height="24" 
                         Margin="0,0,0,8"
                         Padding="2"/>

                <TextBlock Grid.Row="2" Grid.Column="0"
                           Text="Описание:"
                           Margin="0,0,8,0"
                           VerticalAlignment="Top"/>
                <TextBox x:Name="TxtShortDescription" 
                         Grid.Row="2" Grid.Column="1"
                         AcceptsReturn="True"
                         TextWrapping="Wrap"
                         Height="65" 
                         VerticalAlignment="Top"
                         Padding="2"/>

                <!-- Кнопки управления -->
                <StackPanel Grid.Row="3" Grid.Column="0" Grid.ColumnSpan="2"
                            Orientation="Horizontal"
                            HorizontalAlignment="Right"
                            Margin="0,12,0,0">
                    <Button x:Name="BtnAdd"
                            Content="➕ Добавить"
                            Width="90" Height="28" 
                            Margin="0,0,6,0"
                            Click="BtnAdd_Click"
                            Background="#3498DB"
                            Foreground="White"
                            BorderThickness="0"
                            FontSize="11"/>
                    <Button x:Name="BtnSave"
                            Content="💾 Сохранить"
                            Width="80" Height="28" 
                            Margin="0,0,6,0"
                            Click="BtnSave_Click"
                            Background="#2ECC71"
                            Foreground="White"
                            BorderThickness="0"
                            FontSize="11"/>
                    <Button x:Name="BtnDelete"
                            Content="🗑️ Удалить"
                            Width="70" Height="28" 
                            Margin="0,0,6,0"
                            Click="BtnDelete_Click"
                            Background="#E74C3C"
                            Foreground="White"
                            BorderThickness="0"
                            FontSize="11"/>
                    <Button x:Name="BtnClose"
                            Content="❌"
                            Width="28" Height="28" 
                            Margin="0,0,0,0"
                            Click="BtnClose_Click"
                            Background="#95A5A6"
                            Foreground="White"
                            BorderThickness="0"
                            FontSize="12"
                            ToolTip="Закрыть"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- Правая колонка (низ): Панель голосования -->
        <Border Grid.Row="2"
                Background="White"
                CornerRadius="8"
                BorderBrush="#D1D5DB" BorderThickness="1"
                Padding="12" Grid.ColumnSpan="2" Margin="248,0,0,0">

            <StackPanel>
                <TextBlock Text="🗳️ Голосование"
                           FontSize="14"
                           FontWeight="Bold"
                           Foreground="#2C3E50"
                           Margin="0,0,0,8"/>

                <!-- Заголовок с выбранным предметом -->
                <Border Background="#F1F5F9"
                        CornerRadius="6"
                        Padding="8"
                        Margin="0,0,0,12">
                    <TextBlock>
                        <Run Text="Выбранный предмет:" 
                             FontSize="11" 
                             Foreground="#64748B"/>
                        <LineBreak/>
                        <Run x:Name="TxtSelectedSubject" 
                             Text="[выберите в таблице слева]" 
                             FontSize="14" 
                             FontWeight="Bold" 
                             Foreground="#0F172A"/>
                    </TextBlock>
                </Border>

                <!-- Кнопки голосования -->
                <StackPanel Margin="0,0,0,12">
                    <TextBlock Text="Справляешься с материалом?" 
                               FontSize="12" 
                               Foreground="#475569" 
                               Margin="0,0,0,8"
                               HorizontalAlignment="Center"/>

                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="167*"/>
                            <ColumnDefinition Width="114*"/>
                            <ColumnDefinition Width="53*"/>
                            <ColumnDefinition Width="167*"/>
                        </Grid.ColumnDefinitions>

                        <!-- Зеленый -->
                        <Button Grid.Column="0" x:Name="BtnVoteGreen"
                                Content="  🟢 Да!"
                                Background="#10B981"
                                Foreground="White"
                                BorderThickness="0"
                                Height="34" 
                                Width="100"
                                Margin="32,0,35,0"
                                Click="BtnVoteGreen_Click"
                                FontWeight="SemiBold"/>

                        <!-- Желтый -->
                        <Button Grid.Column="1" x:Name="BtnVoteYellow"
                                Content="  🟡 С трудом"
                                Background="#F59E0B"
                                Foreground="White"
                                BorderThickness="0"
                                Height="34" 
                                Width="90"
                                Margin="39,0,39,0"
                                Click="BtnVoteYellow_Click"
                                FontWeight="SemiBold" Grid.ColumnSpan="2"/>

                        <!-- Красный -->
                        <Button Grid.Column="3" x:Name="BtnVoteRed"
                                Content="  🔴 Нет!"
                                Background="#EF4444"
                                Foreground="White"
                                BorderThickness="0"
                                Height="34" 
                                Width="90"
                                Margin="40,0,37,0"
                                Click="BtnVoteRed_Click"
                                FontWeight="SemiBold"/>
                    </Grid>
                </StackPanel>

                <!-- Таймер -->
                <Border Background="#E2E8F0" 
                        CornerRadius="4" 
                        Padding="8,4">
                    <TextBlock x:Name="TxtVoteTimer" 
                               Text="⏱️ Можешь голосовать"
                               FontSize="11"
                               Foreground="#334155"
                               HorizontalAlignment="Center"
                               FontWeight="Medium"/>
                </Border>
            </StackPanel>
        </Border>

        <!-- Нижний блок с рейтингом -->
        <Border Grid.Row="4" Grid.ColumnSpan="2"
        Background="White"
        CornerRadius="8"
        BorderBrush="#D1D5DB" BorderThickness="1"
        Padding="8"
        Margin="0,8,0,0">

            <StackPanel>
                <TextBlock Text="📊 Рейтинг предметов"
                   FontSize="14"
                   FontWeight="Bold"
                   Foreground="#2C3E50"
                   Margin="0,0,0,8"/>

                <DataGrid x:Name="RatingsGrid"
                  AutoGenerateColumns="False"
                  IsReadOnly="True"
                  HeadersVisibility="Column"
                  GridLinesVisibility="Horizontal"
                  RowHeight="24"
                  Height="150"
                  BorderThickness="0">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="Предмет"
                                    Binding="{Binding Name}"
                                    Width="120"/>
                        <DataGridTextColumn Header="Голосов"
                                    Binding="{Binding TotalVotes}"
                                    Width="60"/>
                        <DataGridTextColumn Header="Рейтинг"
                                    Binding="{Binding DisplayScore}"
                                    Width="80"/>
                        <DataGridTemplateColumn Header="Шкала" Width="*">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <Border Background="#EDF2F7"
                                    Height="16"
                                    CornerRadius="3"
                                    Margin="2">
                                        <Border x:Name="ProgressBar"
                                        Width="{Binding BarWidth}"
                                        Height="16"
                                        HorizontalAlignment="Left"
                                        Background="{Binding BarColor}"
                                        CornerRadius="3"/>
                                    </Border>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>
                    </DataGrid.Columns>
                </DataGrid>
            </StackPanel>
        </Border>
    </Grid>
</Window>