<Window x:Class="WPFPPShall.FormLogin"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:WPFPPShall"
        mc:Ignorable="d"
        Title="FormLogin" Height="450" Width="800">
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Заголовок -->
        <TextBlock Grid.Row="0"
                   Text="🔐 Выберите роль"
                   FontSize="18"
                   FontWeight="Bold"
                   Foreground="#2C3E50"
                   HorizontalAlignment="Center"
                   Margin="0,0,0,20"/>

        <!-- Роль -->
        <StackPanel Grid.Row="1" Margin="0,0,0,10">
            <TextBlock Text="Роль:" Margin="0,0,0,5"/>
            <ComboBox x:Name="CmbRole" Height="30">
                <ComboBoxItem Content="👨‍🏫 Учитель" Tag="123"/>
                <ComboBoxItem Content="🛠️ Администратор" Tag="321"/>
                <ComboBoxItem Content="👤 Ученик" Tag="" IsEnabled="False" Opacity="0.5"/>
            </ComboBox>
        </StackPanel>

        <!-- Пароль (только для учителя/админа) -->
        <StackPanel Grid.Row="2" Margin="0,0,0,15">
            <TextBlock Text="Пароль:" Margin="0,0,0,5"/>
            <PasswordBox x:Name="TxtPassword" Height="30"/>
        </StackPanel>

        <!-- Кнопка для школьников (всегда активна) -->
        <Button Grid.Row="3"
                x:Name="BtnStudent"
                Content="👤 Зайти как школьник"
                Height="35"
                Margin="0,0,0,10"
                Background="#3498DB"
                Foreground="White"
                BorderThickness="0"
                FontWeight="SemiBold"
                Click="BtnStudent_Click"/>

        <!-- Кнопка входа для учителя/админа -->
        <Button Grid.Row="4"
                x:Name="BtnLogin"
                Content="Войти"
                Height="35"
                Background="#2ECC71"
                Foreground="White"
                BorderThickness="0"
                FontWeight="SemiBold"
                Click="BtnLogin_Click"/>
    </Grid>
</Window>
