<Window x:Class="WPFPPShall.FormGroups"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:WPFPPShall"
        mc:Ignorable="d"
        Title="FormGroups" Height="450" Width="800">
    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="2*"/>
            <ColumnDefinition Width="3*"/>
        </Grid.ColumnDefinitions>

        <!-- Заголовок -->
        <TextBlock Grid.Row="0" Grid.ColumnSpan="2"
                   Text="Группы (ученические)"
                   FontFamily="Segoe UI"
                   FontSize="16"
                   FontWeight="SemiBold"
                   Margin="0,0,0,8"/>

        <!-- Таблица групп -->
        <Border Grid.Row="1" Grid.Column="0"
                Margin="0,0,8,0"
                Background="White"
                CornerRadius="8"
                BorderBrush="#D1D5DB" BorderThickness="1"
                Padding="4">
            <DataGrid x:Name="GroupsGrid"
                      AutoGenerateColumns="False"
                      IsReadOnly="True"
                      HeadersVisibility="Column"
                      GridLinesVisibility="Horizontal"
                      SelectionMode="Single"
                      SelectionUnit="FullRow"
                      RowHeight="26"
                      AlternationCount="2"
                      SelectionChanged="GroupsGrid_SelectionChanged">
                <DataGrid.Columns>
                    <DataGridTextColumn Header="ID"
                                        Binding="{Binding StudentGroupID}"
                                        Width="60"/>
                    <DataGridTextColumn Header="Группа"
                                        Binding="{Binding GroupName}"
                                        Width="*"/>
                    <DataGridTextColumn Header="Класс"
                                        Binding="{Binding ClassName}"
                                        Width="120"/>
                </DataGrid.Columns>
            </DataGrid>
        </Border>

        <!-- Панель редактирования -->
        <Border Grid.Row="1" Grid.Column="1"
                Background="White"
                CornerRadius="8"
                BorderBrush="#D1D5DB" BorderThickness="1"
                Padding="10">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <TextBlock Grid.Row="0" Grid.Column="0"
                           Text="Название группы:"
                           Margin="0,0,6,6"
                           VerticalAlignment="Center"/>
                <TextBox x:Name="TxtGroupName"
                         Grid.Row="0" Grid.Column="1"
                         Height="24" Margin="0,0,0,6"/>

                <TextBlock Grid.Row="1" Grid.Column="0"
                           Text="Класс:"
                           Margin="0,0,6,6"
                           VerticalAlignment="Center"/>
                <ComboBox x:Name="CbClass"
                          Grid.Row="1" Grid.Column="1"
                          Height="24"
                          DisplayMemberPath="ClassName"
                          SelectedValuePath="ClassID"/>
            </Grid>
        </Border>

        <!-- Нижние кнопки -->
        <StackPanel Grid.Row="2" Grid.ColumnSpan="2"
                    Orientation="Horizontal"
                    HorizontalAlignment="Right"
                    Margin="0,8,0,0">
            <Button x:Name="BtnAdd"
                    Content="Добавить новую"
                    Width="130" Height="26" Margin="0,0,6,0"
                    Click="BtnAdd_Click"/>
            <Button x:Name="BtnSave"
                    Content="Сохранить"
                    Width="100" Height="26" Margin="0,0,6,0"
                    Click="BtnSave_Click"/>
            <Button x:Name="BtnDelete"
                    Content="Удалить"
                    Width="100" Height="26" Margin="0,0,6,0"
                    Click="BtnDelete_Click"/>
            <Button x:Name="BtnClose"
                    Content="Закрыть"
                    Width="90" Height="26"
                    Click="BtnClose_Click"/>
        </StackPanel>
    </Grid>
</Window>
