<Window x:Class="WPFPPShall.FormGenerateSchedule"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:WPFPPShall"
        mc:Ignorable="d"
        Title="🎓 Генератор расписания" 
        Height="700" 
        Width="1100"
        WindowStartupLocation="CenterScreen"
        ResizeMode="CanMinimize">

    <Window.Resources>
        <!-- Светлая тема (по умолчанию) -->
        <SolidColorBrush x:Key="LightBackground" Color="#F8F9FA"/>
        <SolidColorBrush x:Key="LightCard" Color="#FFFFFF"/>
        <SolidColorBrush x:Key="LightBorder" Color="#E1E5E9"/>
        <SolidColorBrush x:Key="LightText" Color="#212529"/>
        <SolidColorBrush x:Key="LightTextSecondary" Color="#6C757D"/>
        <SolidColorBrush x:Key="LightAccent" Color="#4A6FA5"/>
        <SolidColorBrush x:Key="LightAccentHover" Color="#3A5A95"/>
        <SolidColorBrush x:Key="LightSuccess" Color="#28A745"/>

        <!-- Темная тема -->
        <SolidColorBrush x:Key="DarkBackground" Color="#1E1E1E"/>
        <SolidColorBrush x:Key="DarkCard" Color="#252526"/>
        <SolidColorBrush x:Key="DarkBorder" Color="#3E3E42"/>
        <SolidColorBrush x:Key="DarkText" Color="#E0E0E0"/>
        <SolidColorBrush x:Key="DarkTextSecondary" Color="#A0A0A0"/>
        <SolidColorBrush x:Key="DarkAccent" Color="#4A6FA5"/>
        <SolidColorBrush x:Key="DarkAccentHover" Color="#3A5A95"/>
        <SolidColorBrush x:Key="DarkSuccess" Color="#4CAF50"/>

        <!-- Стиль для заголовков -->
        <Style x:Key="HeaderLabel" TargetType="Label">
            <Setter Property="Foreground" Value="{DynamicResource AccentColor}"/>
            <Setter Property="FontSize" Value="16"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
        </Style>

        <!-- Базовый стиль для кнопок -->
        <Style TargetType="Button" x:Key="BaseButtonStyle">
            <Setter Property="Background" Value="{DynamicResource AccentColor}"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="12,8"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" 
                        CornerRadius="8">
                            <ContentPresenter HorizontalAlignment="Center" 
                                      VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="{DynamicResource AccentHover}"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter Property="Background" Value="{DynamicResource AccentColor}"/>
                                <Setter Property="Opacity" Value="0.8"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Стили для тумблера темы -->
        <Style x:Key="ThemeToggleButton" TargetType="ToggleButton">
            <Setter Property="Width" Value="60"/>
            <Setter Property="Height" Value="30"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ToggleButton">
                        <Border x:Name="ToggleBorder"
                            Background="{DynamicResource LightBorder}"
                            CornerRadius="15"
                            BorderThickness="0">
                            <Grid>
                                <Ellipse x:Name="ToggleThumb"
                                     Width="26"
                                     Height="26"
                                     HorizontalAlignment="Left"
                                     Margin="2"
                                     Fill="White"
                                     StrokeThickness="0">
                                    <Ellipse.Effect>
                                        <DropShadowEffect BlurRadius="4" 
                                                      Opacity="0.3" 
                                                      ShadowDepth="1"/>
                                    </Ellipse.Effect>
                                </Ellipse>

                                <!-- Иконки -->
                                <Viewbox Width="12" Height="12" 
                                     HorizontalAlignment="Left" 
                                     Margin="8,0,0,0"
                                     VerticalAlignment="Center">
                                    <Canvas Width="24" Height="24">
                                        <Path Fill="#FFD700" Data="M12,7A5,5 0 0,0 7,12A5,5 0 0,0 12,17A5,5 0 0,0 17,12A5,5 0 0,0 12,7M12,9A3,3 0 0,1 15,12A3,3 0 0,1 12,15A3,3 0 0,1 9,12A3,3 0 0,1 12,9M12,2L14.39,5.42C13.65,5.15 12.84,5 12,5C11.16,5 10.35,5.15 9.61,5.42L12,2M3.34,7L7.5,6.65C6.9,7.16 6.36,7.78 5.94,8.5C5.5,9.24 5.25,10 5.11,10.79L3.34,7M3.36,17L5.12,13.23C5.26,14 5.53,14.78 5.95,15.5C6.37,16.24 6.91,16.86 7.5,17.37L3.36,17M20.65,7L18.88,10.79C18.74,10 18.47,9.23 18.05,8.5C17.63,7.78 17.1,7.15 16.5,6.64L20.65,7M20.64,17L16.5,17.36C17.09,16.85 17.62,16.22 18.04,15.5C18.46,14.77 18.73,14 18.87,13.21L20.64,17M12,22L9.59,18.56C10.33,18.83 11.14,19 12,19C12.82,19 13.63,18.83 14.37,18.56L12,22Z"/>
                                    </Canvas>
                                </Viewbox>

                                <Viewbox Width="12" Height="12" 
                                     HorizontalAlignment="Right" 
                                     Margin="0,0,8,0"
                                     VerticalAlignment="Center">
                                    <Canvas Width="24" Height="24">
                                        <Path Fill="#4A6FA5" Data="M17.75,4.09L15.22,6.03L16.13,9.09L13.5,7.28L10.87,9.09L11.78,6.03L9.25,4.09L12.44,4L13.5,1L14.56,4L17.75,4.09M21.25,11L19.61,12.25L20.2,14.23L18.5,13.06L16.8,14.23L17.39,12.25L15.75,11L17.81,10.95L18.5,9L19.19,10.95L21.25,11M18.97,15.95C19.8,15.87 20.69,17.05 20.16,17.8C19.84,18.25 19.5,18.67 19.08,19.07C15.17,23 8.84,23 4.94,19.07C1.03,15.17 1.03,8.83 4.94,4.93C5.34,4.53 5.76,4.17 6.21,3.85C6.96,3.32 8.14,4.21 8.06,5.04C7.79,7.9 8.75,10.87 10.95,13.06C13.14,15.26 16.1,16.22 18.97,15.95M17.33,17.97C14.5,17.81 11.7,16.61 9.53,14.5C7.36,12.31 6.2,9.5 6.04,6.68C3.23,9.82 3.34,14.64 6.35,17.66C9.37,20.67 14.19,20.78 17.33,17.97Z"/>
                                    </Canvas>
                                </Viewbox>
                            </Grid>
                        </Border>

                        <ControlTemplate.Triggers>
                            <!-- Темная тема (IsChecked = true) -->
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="ToggleBorder" Property="Background" Value="{DynamicResource DarkAccent}"/>
                                <Setter TargetName="ToggleThumb" Property="HorizontalAlignment" Value="Right"/>

                                <!-- Анимация переключения -->
                                <Trigger.EnterActions>
                                    <BeginStoryboard>
                                        <Storyboard>
                                            <ThicknessAnimation Storyboard.TargetName="ToggleThumb"
                                                            Storyboard.TargetProperty="Margin"
                                                            From="2,2,2,2"
                                                            To="32,2,2,2"
                                                            Duration="0:0:0.2"/>
                                        </Storyboard>
                                    </BeginStoryboard>
                                </Trigger.EnterActions>
                            </Trigger>

                            <!-- Светлая тема (IsChecked = false) -->
                            <Trigger Property="IsChecked" Value="False">
                                <Setter TargetName="ToggleThumb" Property="HorizontalAlignment" Value="Left"/>

                                <Trigger.EnterActions>
                                    <BeginStoryboard>
                                        <Storyboard>
                                            <ThicknessAnimation Storyboard.TargetName="ToggleThumb"
                                                            Storyboard.TargetProperty="Margin"
                                                            From="32,2,2,2"
                                                            To="2,2,2,2"
                                                            Duration="0:0:0.2"/>
                                        </Storyboard>
                                    </BeginStoryboard>
                                </Trigger.EnterActions>
                            </Trigger>

                            <!-- Ховер эффект -->
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="ToggleBorder" Property="Opacity" Value="0.9"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid Background="{DynamicResource BackgroundColor}">
        <!-- Основной контейнер -->
        <Border Margin="20" 
            Background="{DynamicResource CardBackground}" 
            CornerRadius="12"
            BorderBrush="{DynamicResource BorderColor}"
            BorderThickness="1">

            <Grid Margin="20">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <!-- Верхняя панель с заголовком -->
                <Border Grid.Row="0" 
        Background="{DynamicResource CardBackground}" 
        CornerRadius="8"
        Padding="15"
        Margin="0,0,0,15">
                    <DockPanel>
                        <!-- Тумблер темы справа -->
                        <StackPanel DockPanel.Dock="Right" 
                    Orientation="Horizontal" 
                    VerticalAlignment="Center">
                            <TextBlock Text="🌙" 
                       FontSize="16"
                       VerticalAlignment="Center"
                       Margin="0,0,5,0"/>

                            <ToggleButton x:Name="ThemeToggle" 
              Style="{StaticResource ThemeToggleButton}"
              Click="ThemeToggle_Click"
                                VerticalAlignment="Center"/>

                            <TextBlock Text="☀️" 
                       FontSize="16"
                       VerticalAlignment="Center"
                       Margin="5,0,0,0"/>
                        </StackPanel>

                        <!-- Заголовок -->
                        <StackPanel>
                            <TextBlock Text="🎯 Генератор расписания уроков" 
                       FontSize="22" 
                       FontWeight="Bold" 
                       Foreground="{DynamicResource AccentColor}"/>
                            <TextBlock Text="Выберите дату и преподавателей для автоматического составления расписания" 
                       FontSize="13" 
                       Foreground="{DynamicResource TextSecondary}"
                       Margin="0,5,0,0"/>
                        </StackPanel>
                    </DockPanel>
                </Border>

                <!-- Основной контент -->
                <Grid Grid.Row="1">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="10"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <!-- Левая колонка - дата и управление -->
                    <Border Grid.Column="0" 
        Background="{DynamicResource CardBackground}" 
        CornerRadius="8"
        Padding="15">
                        <StackPanel>
                            <Label Style="{StaticResource HeaderLabel}" 
               Content="📅 Дата расписания"/>

                            <DatePicker x:Name="DatePickerGen" 
                    Margin="0,10,0,20"
                    SelectedDateFormat="Long"/>

                            <StackPanel Orientation="Horizontal" 
                    Margin="0,10,0,0">
                                <Label Content="Статус:" 
                   Margin="0,0,10,0"
                   Foreground="{DynamicResource TextColor}"/>
                                <TextBlock x:Name="StatusText" 
                       Text="Ожидание выбора" 
                       Foreground="{DynamicResource TextSecondary}"
                       VerticalAlignment="Center"/>
                            </StackPanel>

                            <Separator Margin="0,20,0,10" 
                   Background="{DynamicResource BorderColor}"/>

                            <StackPanel Orientation="Horizontal">
                                <Button x:Name="BtnSelectAll" 
                    Content="✅ Выбрать всех" 
                    Width="120"
                    Margin="0,0,10,0"
                    Style="{StaticResource BaseButtonStyle}"
                    Click="BtnSelectAll_Click"/>
                                <Button x:Name="BtnClearAll" 
                    Content="❌ Очистить выбор" 
                    Width="120"
                    Style="{StaticResource BaseButtonStyle}"
                    Click="BtnClearAll_Click"/>
                            </StackPanel>
                        </StackPanel>
                    </Border>

                    <!-- Разделитель -->
                    <Rectangle Grid.Column="1" 
                               Fill="Transparent"/>

                    <!-- Правая колонка - список учителей -->
                    <Border Grid.Column="2" 
        Background="{DynamicResource CardBackground}" 
        CornerRadius="8"
        Padding="15">
                        <DockPanel>
                            <Label DockPanel.Dock="Top" 
               Style="{StaticResource HeaderLabel}" 
               Content="👨‍🏫 Список преподавателей"
               Margin="0,0,0,10"/>

                            <!-- Поиск по учителям -->
                            <Border DockPanel.Dock="Top"
                Background="{DynamicResource BackgroundColor}"
                CornerRadius="6"
                Padding="8"
                Margin="0,0,0,10">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="🔍" 
                           FontSize="16"
                           Margin="0,0,8,0"
                           VerticalAlignment="Center"
                           Foreground="{DynamicResource TextSecondary}"/>
                                    <TextBox x:Name="SearchTextBox" 
                         Background="Transparent"
                         BorderThickness="0"
                         Foreground="{DynamicResource TextColor}"
                         Padding="4"
                         FontSize="14"
                         Width="200"
                         TextChanged="SearchTextBox_TextChanged"
                         VerticalAlignment="Center">
                                        <TextBox.Style>
                                            <Style TargetType="TextBox">
                                                <Setter Property="CaretBrush" Value="{DynamicResource AccentColor}"/>
                                                <Style.Triggers>
                                                    <Trigger Property="IsMouseOver" Value="True">
                                                        <Setter Property="Background" Value="{DynamicResource BorderColor}"/>
                                                    </Trigger>
                                                </Style.Triggers>
                                            </Style>
                                        </TextBox.Style>
                                    </TextBox>
                                </StackPanel>
                            </Border>

                            <Border DockPanel.Dock="Bottom" 
                Background="{DynamicResource BackgroundColor}" 
                CornerRadius="6"
                Padding="10"
                Margin="0,10,0,0">
                                <StackPanel Orientation="Horizontal" 
                        HorizontalAlignment="Center">
                                    <TextBlock Text="Выбрано: " 
                           Foreground="{DynamicResource TextSecondary}"/>
                                    <TextBlock x:Name="SelectedCountText" 
                           Text="0"
                           Foreground="{DynamicResource AccentColor}"
                           FontWeight="Bold"
                           Margin="5,0,0,0"/>
                                    <TextBlock Text=" / " 
                           Foreground="{DynamicResource TextSecondary}"
                           Margin="5,0,5,0"/>
                                    <TextBlock x:Name="TotalCountText" 
                           Text="0"
                           Foreground="{DynamicResource TextColor}"/>
                                </StackPanel>
                            </Border>

                            <!-- Обновленный ListBox -->
                            <ListBox x:Name="TeacherList" 
                 SelectionMode="Multiple"
                 ScrollViewer.VerticalScrollBarVisibility="Auto"
                 Background="{DynamicResource CardBackground}"
                 Foreground="{DynamicResource TextColor}"
                 BorderBrush="{DynamicResource BorderColor}">
                                <ListBox.ItemTemplate>
                                    <DataTemplate>
                                        <StackPanel Orientation="Horizontal" 
                                Margin="5,2">
                                            <!-- Иконка статуса -->
                                            <Ellipse x:Name="StatusIcon"
                                 Width="12" 
                                 Height="12" 
                                 Fill="{DynamicResource AccentColor}" 
                                 Margin="0,0,10,0"
                                 VerticalAlignment="Center">
                                                <Ellipse.Style>
                                                    <Style TargetType="Ellipse">
                                                        <Setter Property="Fill" Value="{DynamicResource AccentColor}"/>
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding IsBusy}" Value="True">
                                                                <Setter Property="Fill" Value="#FF6B6B"/>
                                                            </DataTrigger>
                                                            <DataTrigger Binding="{Binding IsBusy}" Value="False">
                                                                <Setter Property="Fill" Value="{DynamicResource SuccessColor}"/>
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </Ellipse.Style>
                                            </Ellipse>

                                            <!-- Данные учителя -->
                                            <StackPanel>
                                                <TextBlock Text="{Binding FullName}" 
                                       Foreground="{Binding RelativeSource={RelativeSource AncestorType=ListBoxItem}, Path=Foreground}"
                                       FontWeight="SemiBold"
                                       VerticalAlignment="Center"/>
                                                <TextBlock Text="{Binding Discipline}" 
                                       Foreground="{DynamicResource TextSecondary}"
                                       FontSize="12"
                                       Margin="0,2,0,0"/>
                                            </StackPanel>
                                        </StackPanel>
                                    </DataTemplate>
                                </ListBox.ItemTemplate>
                            </ListBox>
                        </DockPanel>
                    </Border>
                </Grid>

                <!-- Нижняя панель с кнопкой -->
                <Border Grid.Row="2" 
        Background="Transparent" 
        Margin="0,15,0,0">
                    <Grid>
                        <Button x:Name="BtnGenerate" 
                Content="🚀 Сгенерировать расписание" 
                Height="45" 
                Width="250" 
                HorizontalAlignment="Right"
                FontSize="15"
                Style="{StaticResource BaseButtonStyle}"
                Click="BtnGenerate_Click">
                            <Button.Effect>
                                <DropShadowEffect BlurRadius="10" 
                                  Opacity="0.3" 
                                  ShadowDepth="3"/>
                            </Button.Effect>
                        </Button>

                        <!-- Прогресс бар -->
                        <ProgressBar x:Name="ProgressBar" 
                     Height="8" 
                     Width="300" 
                     HorizontalAlignment="Left"
                     VerticalAlignment="Center"
                     Visibility="Collapsed"
                     Foreground="{DynamicResource AccentColor}"/>
                    </Grid>
                </Border>
            </Grid>
        </Border>
    </Grid>
</Window>