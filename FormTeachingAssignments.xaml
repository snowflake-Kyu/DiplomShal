<Window x:Class="WPFPPShall.FormTeachingAssigment"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:WPFPPShall" xmlns:lvc="clr-namespace:LiveCharts.Wpf;assembly=LiveCharts.Wpf"
        mc:Ignorable="d"
        Title="👨‍🏫 Назначение преподавателей" 
        Height="850" 
        Width="1300"
        WindowStartupLocation="CenterScreen"
        ResizeMode="CanMinimize">

    <Window.Resources>
        <!-- Светлая тема -->
        <SolidColorBrush x:Key="BackgroundColor" Color="#F8F9FA"/>
        <SolidColorBrush x:Key="CardBackground" Color="#FFFFFF"/>
        <SolidColorBrush x:Key="BorderColor" Color="#E1E5E9"/>
        <SolidColorBrush x:Key="TextColor" Color="#212529"/>
        <SolidColorBrush x:Key="TextSecondary" Color="#6C757D"/>
        <SolidColorBrush x:Key="AccentColor" Color="#4A6FA5"/>
        <SolidColorBrush x:Key="AccentHover" Color="#3A5A95"/>
        <SolidColorBrush x:Key="SuccessColor" Color="#28A745"/>
        <SolidColorBrush x:Key="DangerColor" Color="#DC3545"/>

        <!-- Базовый стиль для кнопок -->
        <Style x:Key="ModernButton" TargetType="Button">
            <Setter Property="Background" Value="{DynamicResource AccentColor}"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="12,8"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="FontWeight" Value="Medium"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" 
                                CornerRadius="6"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}">
                            <ContentPresenter HorizontalAlignment="Center" 
                                              VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="{DynamicResource AccentHover}"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter Property="Opacity" Value="0.9"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Стиль для вторичных кнопок -->
        <Style x:Key="SecondaryButton" TargetType="Button" BasedOn="{StaticResource ModernButton}">
            <Setter Property="Background" Value="White"/>
            <Setter Property="Foreground" Value="{DynamicResource TextColor}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource BorderColor}"/>
            <Setter Property="BorderThickness" Value="1"/>
        </Style>

        <!-- Стиль для текстбоксов -->
        <Style TargetType="TextBox">
            <Setter Property="Background" Value="White"/>
            <Setter Property="Foreground" Value="{DynamicResource TextColor}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource BorderColor}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="8,6"/>
            <Setter Property="FontSize" Value="13"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="BorderBrush" Value="{DynamicResource AccentColor}"/>
                </Trigger>
                <Trigger Property="IsFocused" Value="True">
                    <Setter Property="BorderBrush" Value="{DynamicResource AccentColor}"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <!-- Стиль для комбобоксов -->
        <Style TargetType="ComboBox">
            <Setter Property="Background" Value="White"/>
            <Setter Property="Foreground" Value="{DynamicResource TextColor}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource BorderColor}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="8,6"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="BorderBrush" Value="{DynamicResource AccentColor}"/>
                </Trigger>
                <Trigger Property="IsFocused" Value="True">
                    <Setter Property="BorderBrush" Value="{DynamicResource AccentColor}"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <!-- Стиль для карточек назначений -->
        <Style x:Key="AssignmentCardStyle" TargetType="Border">
            <Setter Property="CornerRadius" Value="8"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="BorderBrush" Value="{DynamicResource BorderColor}"/>
            <Setter Property="Background" Value="{DynamicResource CardBackground}"/>
            <Setter Property="Padding" Value="15"/>
            <Setter Property="Margin" Value="0,0,0,8"/>
            <Setter Property="Effect">
                <Setter.Value>
                    <DropShadowEffect BlurRadius="6" 
                                      ShadowDepth="1" 
                                      Opacity="0.1"/>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Стиль для ListViewItem -->
        <Style TargetType="ListViewItem">
            <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
            <Setter Property="Padding" Value="0"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="{DynamicResource BorderColor}"/>
                </Trigger>
                <Trigger Property="IsSelected" Value="True">
                    <Setter Property="Panel.ZIndex" Value="1"/>
                    <Setter Property="Background" Value="Transparent"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <!-- Стиль для DataGrid -->
        <Style TargetType="DataGridColumnHeader">
            <Setter Property="Background" Value="#F1F3F4"/>
            <Setter Property="Foreground" Value="{DynamicResource TextColor}"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="HorizontalContentAlignment" Value="Center"/>
            <Setter Property="Height" Value="36"/>
            <Setter Property="Padding" Value="10,0"/>
            <Setter Property="BorderThickness" Value="0,0,0,1"/>
            <Setter Property="BorderBrush" Value="{DynamicResource BorderColor}"/>
        </Style>

        <Style TargetType="DataGridRow">
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Background" Value="White"/>
            <Setter Property="BorderBrush" Value="Transparent"/>
            <Setter Property="Height" Value="34"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#F8F9FA"/>
                </Trigger>
                <Trigger Property="IsSelected" Value="True">
                    <Setter Property="Background" Value="#E3F2FD"/>
                    <Setter Property="FontWeight" Value="Medium"/>
                </Trigger>
                <Trigger Property="ItemsControl.AlternationIndex" Value="1">
                    <Setter Property="Background" Value="#FAFAFA"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style TargetType="DataGridCell">
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="10,6"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
        </Style>

    </Window.Resources>

    <Grid Background="{DynamicResource BackgroundColor}" Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <!-- фильтры -->
            <RowDefinition Height="Auto"/>
            <!-- редактор -->
            <RowDefinition Height="*"/>
            <!-- список/таблица -->
            <RowDefinition Height="Auto"/>
            <!-- кнопки -->
            <RowDefinition Height="220"/>
        </Grid.RowDefinitions>

        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- Панель фильтров -->
        <Border Grid.Row="0" 
                Background="{DynamicResource CardBackground}" 
                CornerRadius="8"
                Padding="15"
                BorderBrush="{DynamicResource BorderColor}"
                BorderThickness="1"
                Margin="0,0,0,10">
            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                <TextBlock Text="Фильтр по учителю:" 
                           VerticalAlignment="Center" 
                           Margin="0,0,8,0"
                           FontWeight="Medium"
                           Foreground="{DynamicResource TextColor}"/>

                <ComboBox x:Name="CbFilterTeacher" 
                          Width="240" 
                          Height="36"
                          DisplayMemberPath="FullName" 
                          SelectedValuePath="TeacherID"
                          SelectionChanged="CbFilterTeacher_SelectionChanged"/>

                <Button Content="Очистить фильтр" 
                        Margin="12,0,0,0" 
                        Height="36"
                        Padding="12,0"
                        Style="{StaticResource SecondaryButton}"
                        Click="BtnClearFilter_Click"/>

                <TextBlock Text="Быстрый поиск:" 
                           VerticalAlignment="Center" 
                           Margin="24,0,8,0"
                           FontWeight="Medium"
                           Foreground="{DynamicResource TextColor}"/>

                <TextBox x:Name="TxtFilterAssignments"
                         Width="280"
                         Height="36"
                         VerticalAlignment="Center"
                         TextChanged="TxtFilterAssignments_TextChanged"/>
            </StackPanel>
        </Border>

        <!-- Панель редактирования -->
        <Border Grid.Row="1" 
                Background="{DynamicResource CardBackground}" 
                CornerRadius="8"
                Padding="15" 
                BorderBrush="{DynamicResource BorderColor}" 
                BorderThickness="1"
                Margin="0,0,0,10">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <!-- Учитель -->
                <TextBlock Grid.Row="0" Grid.Column="0" 
                           Text="Учитель:" 
                           VerticalAlignment="Center" 
                           Margin="0,0,8,8"
                           FontWeight="Medium"
                           Foreground="{DynamicResource TextColor}"/>

                <ComboBox x:Name="CbTeacher" 
                          Grid.Row="0" Grid.Column="1" 
                          Height="36"
                          DisplayMemberPath="FullName" 
                          SelectedValuePath="TeacherID"
                          Margin="0,0,0,8"/>

                <!-- Дисциплина -->
                <TextBlock Grid.Row="0" Grid.Column="2" 
                           Text="Дисциплина:" 
                           VerticalAlignment="Center" 
                           Margin="16,0,8,8"
                           FontWeight="Medium"
                           Foreground="{DynamicResource TextColor}"/>

                <ComboBox x:Name="CbDiscipline" 
                          Grid.Row="0" Grid.Column="3" 
                          Height="36"
                          DisplayMemberPath="Name" 
                          SelectedValuePath="DisciplineID"
                          Margin="0,0,0,8"/>

                <!-- Аудитория -->
                <TextBlock Grid.Row="1" Grid.Column="0" 
                           Text="Аудитория:" 
                           VerticalAlignment="Center" 
                           Margin="0,0,8,8"
                           FontWeight="Medium"
                           Foreground="{DynamicResource TextColor}"/>

                <ComboBox x:Name="CbAuditorium" 
                          Grid.Row="1" Grid.Column="1" 
                          Height="36"
                          DisplayMemberPath="Name" 
                          SelectedValuePath="AuditoriumID"
                          Margin="0,0,0,8"/>

                <!-- Комментарий -->
                <TextBlock Grid.Row="1" Grid.Column="2" 
                           Text="Комментарий:" 
                           VerticalAlignment="Center" 
                           Margin="16,0,8,8"
                           FontWeight="Medium"
                           Foreground="{DynamicResource TextColor}"/>

                <TextBox x:Name="TxtComment" 
                         Grid.Row="1" Grid.Column="3" 
                         Height="36"
                         Margin="0,0,0,8"/>

                <!-- Кнопки действий -->
                <StackPanel Grid.Row="2" Grid.Column="0" Grid.ColumnSpan="4" 
                            Orientation="Horizontal" 
                            HorizontalAlignment="Right" 
                            Margin="0,8,0,0">
                    <Button x:Name="BtnNew" 
                            Content="➕ Новый" 
                            Width="100" 
                            Height="36"
                            Style="{StaticResource ModernButton}"
                            Click="BtnNew_Click" 
                            Margin="0,0,8,0"/>

                    <Button x:Name="BtnSave" 
                            Content="💾 Сохранить" 
                            Width="110" 
                            Height="36"
                            Style="{StaticResource ModernButton}"
                            Click="BtnSave_Click" 
                            Margin="0,0,8,0"/>

                    <Button x:Name="BtnDelete" 
                            Content="🗑️ Удалить" 
                            Width="110" 
                            Height="36"
                            Click="BtnDelete_Click"
                            Background="{DynamicResource DangerColor}">
                        <Button.Style>
                            <Style TargetType="Button" BasedOn="{StaticResource ModernButton}">
                                <Setter Property="Background" Value="{DynamicResource DangerColor}"/>
                                <Style.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter Property="Background" Value="#C82333"/>
                                    </Trigger>
                                </Style.Triggers>
                            </Style>
                        </Button.Style>
                    </Button>
                </StackPanel>
            </Grid>
        </Border>

        <!-- Таблица ИЛИ ListView с карточками -->
        <TabControl Grid.Row="2" 
                    Background="Transparent"
                    BorderThickness="0"
                    Margin="0,0,0,10">
            <TabControl.Resources>
                <Style TargetType="TabItem">
                    <Setter Property="Background" Value="Transparent"/>
                    <Setter Property="BorderBrush" Value="Transparent"/>
                    <Setter Property="Padding" Value="12,6"/>
                    <Setter Property="Margin" Value="0,0,8,0"/>
                    <Setter Property="FontWeight" Value="Medium"/>
                    <Setter Property="FontSize" Value="13"/>
                    <Setter Property="Foreground" Value="{DynamicResource TextSecondary}"/>
                    <Setter Property="Template">
                        <Setter.Value>
                            <ControlTemplate TargetType="TabItem">
                                <Border Name="Border" 
                                        Background="Transparent"
                                        BorderBrush="Transparent"
                                        BorderThickness="0"
                                        CornerRadius="6,6,0,0"
                                        Padding="{TemplateBinding Padding}">
                                    <ContentPresenter x:Name="ContentSite"
                                                      VerticalAlignment="Center"
                                                      HorizontalAlignment="Center"
                                                      ContentSource="Header"/>
                                </Border>
                                <ControlTemplate.Triggers>
                                    <Trigger Property="IsSelected" Value="True">
                                        <Setter TargetName="Border" Property="BorderBrush" Value="{DynamicResource AccentColor}"/>
                                        <Setter TargetName="Border" Property="BorderThickness" Value="0,0,0,2"/>
                                        <Setter Property="Foreground" Value="{DynamicResource AccentColor}"/>
                                    </Trigger>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter Property="Foreground" Value="{DynamicResource TextColor}"/>
                                    </Trigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </Setter.Value>
                    </Setter>
                </Style>
            </TabControl.Resources>

            <!-- Вкладка с таблицей -->
            <TabItem Header="📋 Таблица">
                <Border Background="{DynamicResource CardBackground}" 
                        CornerRadius="8"
                        BorderBrush="{DynamicResource BorderColor}"
                        BorderThickness="1">
                    <DataGrid x:Name="AssignmentsGrid" 
                              AutoGenerateColumns="False" 
                              HeadersVisibility="Column"
                              SelectionMode="Single" 
                              SelectionUnit="FullRow" 
                              RowHeight="34" 
                              SelectionChanged="AssignmentsGrid_SelectionChanged"
                              GridLinesVisibility="Horizontal"
                              AlternationCount="2"
                              BorderThickness="0">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="ID" 
                                                Binding="{Binding AssignmentID}" 
                                                Width="70"/>
                            <DataGridTextColumn Header="Учитель" 
                                                Binding="{Binding FullName}" 
                                                Width="220"/>
                            <DataGridTextColumn Header="Дисциплина" 
                                                Binding="{Binding DisciplineName}" 
                                                Width="220"/>
                            <DataGridTextColumn Header="Аудитория" 
                                                Binding="{Binding AuditoriumName}" 
                                                Width="160"/>
                            <DataGridTextColumn Header="Комментарий" 
                                                Binding="{Binding Comment}" 
                                                Width="*"/>
                        </DataGrid.Columns>
                    </DataGrid>
                </Border>
            </TabItem>

            <!-- Вкладка с карточками -->
            <TabItem Header="🎴 Карточки">
                <Border Background="{DynamicResource CardBackground}" 
                        CornerRadius="8"
                        BorderBrush="{DynamicResource BorderColor}"
                        BorderThickness="1">
                    <ScrollViewer VerticalScrollBarVisibility="Auto"
                                  HorizontalScrollBarVisibility="Disabled"
                                  Padding="10">
                        <ListView x:Name="AssignmentsListView"
                                  SelectionMode="Single"
                                  Background="Transparent"
                                  BorderThickness="0"
                                  SelectionChanged="AssignmentsGrid_SelectionChanged">
                            <ListView.ItemTemplate>
                                <DataTemplate>
                                    <Border Style="{StaticResource AssignmentCardStyle}">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="Auto"/>
                                                <ColumnDefinition Width="*"/>
                                            </Grid.ColumnDefinitions>

                                            <!-- Левая часть - иконка -->
                                            <Border Grid.Column="0"
                                                    Width="50"
                                                    Height="50"
                                                    Background="{DynamicResource AccentColor}"
                                                    CornerRadius="25"
                                                    Margin="0,0,15,0">
                                                <TextBlock Text="👨‍🏫"
                                                           FontSize="24"
                                                           HorizontalAlignment="Center"
                                                           VerticalAlignment="Center"/>
                                            </Border>

                                            <!-- Правая часть - информация -->
                                            <StackPanel Grid.Column="1">
                                                <!-- Заголовок карточки -->
                                                <StackPanel Orientation="Horizontal" 
                                                            Margin="0,0,0,6">
                                                    <TextBlock Text="{Binding FullName, Mode=OneWay}"
                                                               FontWeight="Bold"
                                                               FontSize="15"
                                                               Foreground="{DynamicResource AccentColor}"/>
                                                    <TextBlock Text=" · "
                                                               Foreground="{DynamicResource TextSecondary}"
                                                               FontWeight="SemiBold"/>
                                                    <TextBlock Text="ID: "
                                                               Foreground="{DynamicResource TextSecondary}"
                                                               FontSize="13"/>
                                                    <TextBlock Text="{Binding AssignmentID, Mode=OneWay}"
                                                               Foreground="{DynamicResource TextSecondary}"
                                                               FontSize="13"
                                                               FontWeight="Medium"/>
                                                </StackPanel>

                                                <!-- Основная информация -->
                                                <StackPanel Margin="0,8,0,0">
                                                    <!-- Дисциплина -->
                                                    <StackPanel Orientation="Horizontal" 
                                                                Margin="0,0,0,4">
                                                        <TextBlock Text="📚 "
                                                                   Foreground="{DynamicResource TextSecondary}"
                                                                   FontSize="13"/>
                                                        <TextBlock Text="{Binding DisciplineName, Mode=OneWay}"
                                                                   FontSize="13"
                                                                   Foreground="{DynamicResource TextColor}"/>
                                                    </StackPanel>

                                                    <!-- Аудитория -->
                                                    <StackPanel Orientation="Horizontal" 
                                                                Margin="0,0,0,4">
                                                        <TextBlock Text="🏢 "
                                                                   Foreground="{DynamicResource TextSecondary}"
                                                                   FontSize="13"/>
                                                        <TextBlock Text="{Binding AuditoriumName, Mode=OneWay}"
                                                                   FontSize="13"
                                                                   Foreground="{DynamicResource TextColor}"/>
                                                    </StackPanel>

                                                    <!-- Комментарий -->
                                                    <StackPanel Orientation="Horizontal" 
                                                                Margin="0,6,0,0">
                                                        <TextBlock Text="💬 "
                                                                   Foreground="{DynamicResource TextSecondary}"
                                                                   FontSize="13"/>
                                                        <TextBlock Text="{Binding Comment, Mode=OneWay}"
                                                                   FontSize="13"
                                                                   Foreground="{DynamicResource TextSecondary}"
                                                                   FontStyle="Italic"
                                                                   TextWrapping="Wrap"/>
                                                    </StackPanel>
                                                </StackPanel>
                                            </StackPanel>
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ListView.ItemTemplate>

                            <ListView.ItemContainerStyle>
                                <Style TargetType="ListViewItem" BasedOn="{StaticResource {x:Type ListViewItem}}">
                                    <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                                    <Setter Property="Padding" Value="10,0"/>
                                    <Setter Property="Margin" Value="0,0,0,8"/>
                                </Style>
                            </ListView.ItemContainerStyle>
                        </ListView>
                    </ScrollViewer>
                </Border>
            </TabItem>
        </TabControl>

        <!-- Панель кнопок -->
        <Border Grid.Row="3" 
                Background="{DynamicResource CardBackground}" 
                CornerRadius="8"
                Padding="12"
                BorderBrush="{DynamicResource BorderColor}"
                BorderThickness="1">
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                <Button Content="🔄 Обновить" 
                        Width="120" 
                        Height="36"
                        Style="{StaticResource SecondaryButton}"
                        Click="BtnRefresh_Click" 
                        Margin="0,0,8,0"/>

                <Button Content="✖️ Закрыть" 
                        Width="100" 
                        Height="36"
                        Style="{StaticResource ModernButton}"
                        Click="BtnClose_Click"/>
            </StackPanel>
        </Border>
        <!-- График нагрузки учителей -->
        <Border Grid.Row="4" 
        Background="{DynamicResource CardBackground}" 
        CornerRadius="8"
        Padding="10"
        BorderBrush="{DynamicResource BorderColor}"
        BorderThickness="1"
        Margin="0,10,0,0">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <TextBlock Text="📊 Количество предметов по учителям" 
                   FontWeight="Bold" 
                   FontSize="14"
                   Margin="0,0,0,10"
                   Foreground="{DynamicResource TextColor}"/>

                <lvc:CartesianChart Grid.Row="1" 
                            x:Name="TeacherLoadChart"
                            LegendLocation="Top"
                            Background="Transparent">
                    <lvc:CartesianChart.Series>
                        <lvc:ColumnSeries x:Name="ColumnSeries1"
                                  Title="Предметов"
                                  Values="{Binding DisciplineCount}"
                                  Fill="#4A6FA5"/>
                    </lvc:CartesianChart.Series>
                    <lvc:CartesianChart.AxisX>
                        <lvc:Axis Title="Учителя" 
                          Labels="{Binding TeacherName}"
                          FontSize="10"
                          LabelsRotation="-30"/>
                    </lvc:CartesianChart.AxisX>
                    <lvc:CartesianChart.AxisY>
                        <lvc:Axis Title="Количество предметов" 
                          FontSize="11"
                          MinValue="0"/>
                    </lvc:CartesianChart.AxisY>
                </lvc:CartesianChart>
            </Grid>
        </Border>
    </Grid>
</Window>