<Window x:Class="WPFPPShall.ReportWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:WPFPPShall"
        mc:Ignorable="d"
        Title="ReportWindow" Height="700" Width="1000">
    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Выбор типа отчета -->
        <GroupBox Header="Тип отчета" Grid.Row="0" Margin="5">
            <StackPanel Orientation="Horizontal">
                <RadioButton x:Name="rbSchedule" Content="Расписание занятий" 
                             IsChecked="True" Margin="10,5" Checked="ReportTypeChanged"/>
                <RadioButton x:Name="rbTeacherLoad" Content="Нагрузка учителей" 
                             Margin="10,5" Checked="ReportTypeChanged"/>
                <RadioButton x:Name="rbVotes" Content="Оценки дисциплин" 
                             Margin="10,5" Checked="ReportTypeChanged"/>
            </StackPanel>
        </GroupBox>

        <!-- Панель фильтров -->
        <Border BorderBrush="LightGray" BorderThickness="1" CornerRadius="5" 
                Grid.Row="1" Margin="5" Padding="10">
            <StackPanel>
                <TextBlock Text="Фильтры" FontWeight="Bold" Margin="0,0,0,10"/>
                <WrapPanel>
                    <!-- Фильтр по датам -->
                    <Border x:Name="filterDatePanel" Margin="0,0,15,10">
                        <StackPanel>
                            <TextBlock Text="Период:"/>
                            <StackPanel Orientation="Horizontal">
                                <DatePicker x:Name="dpStartDate" Width="120" Margin="0,5,5,0"/>
                                <TextBlock Text="—" VerticalAlignment="Center"/>
                                <DatePicker x:Name="dpEndDate" Width="120" Margin="5,5,0,0"/>
                            </StackPanel>
                        </StackPanel>
                    </Border>

                    <!-- Фильтр по классам -->
                    <Border x:Name="filterClassPanel" Margin="0,0,15,10">
                        <StackPanel>
                            <TextBlock Text="Класс:"/>
                            <ComboBox x:Name="cbClass" Width="150" Margin="0,5,0,0"
                                      DisplayMemberPath="ClassName" SelectedValuePath="ClassID"/>
                        </StackPanel>
                    </Border>

                    <!-- Фильтр по дисциплинам -->
                    <Border x:Name="filterDisciplinePanel" Margin="0,0,15,10">
                        <StackPanel>
                            <TextBlock Text="Дисциплина:"/>
                            <ComboBox x:Name="cbDiscipline" Width="150" Margin="0,5,0,0"
                                      DisplayMemberPath="Name" SelectedValuePath="DisciplineID"/>
                        </StackPanel>
                    </Border>

                    <!-- Фильтр по учителям -->
                    <Border x:Name="filterTeacherPanel" Margin="0,0,15,10">
                        <StackPanel>
                            <TextBlock Text="Учитель:"/>
                            <ComboBox x:Name="cbTeacher" Width="200" Margin="0,5,0,0"
                                      DisplayMemberPath="FullName" SelectedValuePath="TeacherID"/>
                        </StackPanel>
                    </Border>
                </WrapPanel>

                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                    <Button x:Name="btnSearch" Content="Применить фильтры" Width="120" 
                            Height="30" Margin="5" Click="BtnSearch_Click" Background="LightBlue"/>
                    <Button x:Name="btnReset" Content="Сбросить" Width="80" 
                            Height="30" Margin="5" Click="BtnReset_Click"/>
                    <Button x:Name="btnExport" Content="Экспорт в Excel" Width="120" 
                            Height="30" Margin="5" Click="BtnExport_Click" Background="LightGreen"/>
                </StackPanel>
            </StackPanel>
        </Border>

        <!-- DataGrid для отображения отчета -->
        <DataGrid x:Name="dgReport" Grid.Row="2" Margin="5" 
                  AutoGenerateColumns="True" CanUserAddRows="False"
                  IsReadOnly="True" AlternatingRowBackground="LightYellow"
                  >
            <DataGrid.Resources>
                <Style TargetType="DataGridColumnHeader">
                    <Setter Property="Background" Value="LightGray"/>
                    <Setter Property="FontWeight" Value="Bold"/>
                    <Setter Property="HorizontalContentAlignment" Value="Center"/>
                </Style>
            </DataGrid.Resources>
        </DataGrid>

        <!-- Статусбар -->
        <StatusBar Grid.Row="3">
            <StatusBarItem>
                <TextBlock x:Name="tbStatus" Text="Готов" />
            </StatusBarItem>
        </StatusBar>
    </Grid>
</Window>
