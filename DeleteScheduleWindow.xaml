<Window x:Class="WPFPPShall.DeleteScheduleWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:WPFPPShall"
        mc:Ignorable="d"
        Title="DeleteScheduleWindow" Height="161" Width="419">
    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0"
                   Text="Что нужно удалить?"
                   FontFamily="Segoe UI"
                   FontSize="14"
                   FontWeight="SemiBold"
                   Margin="0,0,0,8"/>

        <StackPanel Grid.Row="1">
            <RadioButton x:Name="rbClassForDay"
                         Content="Все уроки выбранного класса на выбранную дату"
                         IsChecked="True"
                         Margin="0,0,0,4"/>
            <RadioButton x:Name="rbAllForDay"
                         Content="Все уроки всех классов на выбранную дату"
                         Margin="0,0,0,8"/>

            <TextBlock Text="Внимание! Операция необратима: данные будут физически удалены из базы."
                       TextWrapping="Wrap"
                       Foreground="DarkRed"
                       FontSize="11"/>
        </StackPanel>

        <StackPanel Grid.Row="2"
                    Orientation="Horizontal"
                    HorizontalAlignment="Right"
                    Margin="0,10,0,0">
            <Button Content="Отмена" Width="90" Margin="0,0,8,0"
                    IsCancel="True" Click="BtnCancel_Click"/>
            <Button Content="Удалить" Width="90"
                    IsDefault="True" Click="BtnOk_Click"/>
        </StackPanel>
    </Grid>
</Window>
